{
	"name": "citra",
	"version": "0.27.0",
	"description": "OAuth2 library for Typescript",
	"repository": {
		"type": "git",
		"url": "https://github.com/absolutejs/citra.git"
	},
	"main": "./dist/index.js",
	"types": "./dist/src/index.d.ts",
	"license": "CC BY-NC 4.0",
	"author": "Alex Kahn",
	"scripts": {
		"build": "rm -rf dist && bun build src/index.ts --outdir dist --target=bun --external elysia && tsc --emitDeclarationOnly --project tsconfig.json",
		"test": "echo \"Error: no test specified\" && exit 1",
		"format": "prettier --write \"./**/*.{js,jsx,ts,tsx,css,json,mjs,md}\"",
		"dev": "bun run --watch --no-clear-screen example/server.ts",
		"lint": "eslint ./src ./example ./eslint.config.mjs",
		"typecheck": "bun run tsc --noEmit",
		"release": "bun run format && bun run build && bun publish"
	},
	"devDependencies": {
		"@elysiajs/static": "1.4.10",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/bun": "1.3.14",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"elysia": "1.4.28",
		"eslint": "^9",
		"eslint-plugin-absolute": "0.9.0",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-promise": "7.3.0",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-compiler": "19.1.0-rc.2",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-security": "4.0.0",
		"globals": "^17.6.0",
		"prettier": "3.8.3",
		"react": "19.2.6",
		"react-icons": "^5.6.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.3"
	}
}
